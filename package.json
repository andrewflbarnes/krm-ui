{
  "name": "krm-ui",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "PWA=true vite build",
    "postinstall": "./netlify/functions/install.sh",
    "start": "vite",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "pnpm exec oxlint && pnpm exec eslint",
    "e2e": "playwright test --retries 2",
    "e2e:ui": "cross-env PLAYWRIGHT_NO_PARALLEL=true playwright test --ui",
    "e2e:report": "playwright show-report",
    "check": "tsc --noEmit --skipLibCheck",
    "serve": "cp serve.json dist/ && serve -l 5173 dist/",
    "ngrok": "ngrok start krm",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o dist/krm-ui-storybook"
  },
  "dependencies": {
    "@alenaksu/json-viewer": "^2.1.2",
    "@clerk/themes": "^2.4.57",
    "@fontsource/roboto": "^5.2.10",
    "@solidjs/router": "^0.15.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@suid/icons-material": "^0.9.0",
    "@suid/material": "^0.19.0",
    "@suid/system": "^0.14.0",
    "@tanstack/solid-query": "^5.96.2",
    "@thisbeyond/solid-dnd": "^0.7.5",
    "clerk-solidjs": "^2.0.10",
    "downloadjs": "^1.4.7",
    "firebase": "^11.10.0",
    "jotai": "^2.19.0",
    "solid-jotai": "^0.3.1",
    "solid-js": "^1.9.12",
    "solid-toast": "^0.5.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^9.39.4",
    "@netlify/plugin-lighthouse": "^6.0.4",
    "@playwright/test": "^1.59.1",
    "@solidjs/testing-library": "^0.8.10",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@suid/types": "^0.8.0",
    "@suid/vite-plugin": "^0.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/downloadjs": "^1.4.6",
    "@types/node": "^22.19.17",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-oxlint": "^1.58.0",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-storybook": "^10.3.4",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "oxlint": "^1.58.0",
    "playwright": "^1.59.1",
    "serve": "^14.2.6",
    "storybook": "^10.3.4",
    "storybook-solidjs-vite": "10.0.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "@storybook/builder-vite": "$storybook",
      "@storybook/csf-plugin": "$storybook"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "puppeteer"
    ]
  },
  "packageManager": "pnpm@10.6.4+sha512.da3d715bfd22a9a105e6e8088cfc7826699332ded60c423b14ec613a185f1602206702ff0fe4c438cb15c979081ce4cb02568e364b15174503a63c7a8e2a5f6c",
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
